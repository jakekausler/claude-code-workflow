# GitHub OAuth credentials for authentication
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Secret key used to sign and verify JSON Web Tokens
JWT_SECRET=your_jwt_secret_key

# PostgreSQL connection string (constructed automatically in docker-compose if not set)
DATABASE_URL=postgres://claude:your_password@postgres:5432/claude_workflow

# Application environment
NODE_ENV=production

# PostgreSQL database configuration
POSTGRES_DB=claude_workflow
POSTGRES_USER=claude
POSTGRES_PASSWORD=your_password

# Slack integration testing
SLACK_TEST_WEBHOOK_URL=
SLACK_BOT_TOKEN=
